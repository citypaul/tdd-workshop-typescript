{
  "name": "tdd-workshop-typescript",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "TypeScript TDD workshop materials with lab checkpoints.",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10 <12"
  },
  "scripts": {
    "preinstall": "node src/demo-booking-system/scripts/check-node-version.js",
    "postinstall": "playwright install chromium",
    "install:browsers": "playwright install chromium",
    "dev": "pnpm dev:card",
    "dev:card": "vite --config src/card-validator/vite.config.ts",
    "start:lab1": "node scripts/switch-lab.mjs lab1",
    "start:lab2": "node scripts/switch-lab.mjs lab2",
    "start:lab3": "node scripts/switch-lab.mjs lab3",
    "dev:booking": "concurrently --kill-others-on-fail --names api,web \"pnpm dev:booking:api\" \"pnpm dev:booking:web\"",
    "dev:booking:web": "vite --config src/demo-booking-system/vite.config.ts",
    "dev:booking:api": "tsx watch src/demo-booking-system/api/main.ts",
    "start:booking:api": "tsx src/demo-booking-system/api/main.ts",
    "build": "pnpm build:card && pnpm build:booking",
    "build:card": "vite build --config src/card-validator/vite.config.ts",
    "build:booking": "tsc -p src/demo-booking-system/tsconfig.json --noEmit && vite build --config src/demo-booking-system/vite.config.ts",
    "typecheck:booking": "tsc -p src/demo-booking-system/tsconfig.json --noEmit",
    "test": "pnpm test:card && pnpm test:booking",
    "test:card": "vitest run --config src/card-validator/vite.config.ts",
    "test:card:unit": "vitest run --config src/card-validator/vite.config.ts --project=unit",
    "test:card:browser": "vitest run --config src/card-validator/vite.config.ts --project=browser",
    "test:card:watch": "vitest --config src/card-validator/vite.config.ts",
    "test:card:watch:ui": "vitest --config src/card-validator/vite.config.ts --project=browser --browser.headless=false --ui",
    "test:scripts": "node --test scripts/*.test.mjs",
    "test:booking": "vitest run --config src/demo-booking-system/vitest.config.ts --project good-node --project good-browser",
    "test:booking:watch": "vitest --config src/demo-booking-system/vitest.config.ts --project good-node --project good-browser",
    "test:booking:good": "vitest run --config src/demo-booking-system/vitest.config.ts --project good-node --project good-browser",
    "test:booking:domain": "vitest run --config src/demo-booking-system/vitest.config.ts --project good-node domain",
    "test:booking:domain:watch": "vitest --config src/demo-booking-system/vitest.config.ts --project good-node domain",
    "test:booking:api": "vitest run --config src/demo-booking-system/vitest.config.ts --project good-node api",
    "test:booking:api:watch": "vitest --config src/demo-booking-system/vitest.config.ts --project good-node api",
    "test:booking:web": "vitest run --config src/demo-booking-system/vitest.config.ts --project good-node --project good-browser web",
    "test:booking:web:watch": "vitest --config src/demo-booking-system/vitest.config.ts --project good-node --project good-browser web",
    "test:booking:mirror": "vitest run --config src/demo-booking-system/vitest.config.ts --project mirror --passWithNoTests",
    "test:booking:all": "vitest run --config src/demo-booking-system/vitest.config.ts",
    "test:coverage": "pnpm test:card -- --coverage && pnpm test:booking -- --coverage",
    "test:booking:ui": "vitest run --config src/demo-booking-system/vitest.config.ts --project good-browser --browser.headless=false",
    "test:booking:watch:ui": "vitest --config src/demo-booking-system/vitest.config.ts --project good-node --project good-browser --ui --browser.headless=false",
    "lint": "eslint -c src/demo-booking-system/eslint.config.js src/demo-booking-system",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -c src/demo-booking-system/.storybook -p 6006",
    "build-storybook": "storybook build -c src/demo-booking-system/.storybook",
    "mutation:booking": "stryker run src/demo-booking-system/stryker.conf.mjs",
    "mutation:booking:diff": "bash src/demo-booking-system/scripts/mutation-diff.sh",
    "mutation:booking:mirror": "stryker run src/demo-booking-system/stryker.mirror.conf.mjs",
    "acceptance:booking": "playwright test --config src/demo-booking-system/playwright.config.ts",
    "acceptance:booking:ui": "playwright test --config src/demo-booking-system/playwright.config.ts --ui"
  },
  "dependencies": {
    "@hono/node-server": "1.19.14",
    "@tanstack/react-query": "5.99.2",
    "hono": "4.12.14",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-svg-credit-card-payment-icons": "5.1.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser": "4.1.4",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "4.1.4",
    "axe-core": "4.11.3",
    "concurrently": "9.2.1",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-storybook": "^10.3.5",
    "fast-check": "4.5.3",
    "globals": "17.5.0",
    "msw": "2",
    "playwright": "1.59.1",
    "playwright-msw": "3.0.1",
    "prettier": "3.8.3",
    "storybook": "^10.3.5",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.8",
    "vitest": "4.1.4",
    "vitest-browser-react": "2.2.0"
  },
  "msw": {
    "workerDirectory": [
      "src/demo-booking-system/public"
    ]
  }
}
